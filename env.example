POSTGRES_USER=finbud
POSTGRES_PASSWORD=finbud_secret
POSTGRES_DB=finbud_db
POSTGRES_SSLMODE=disable

REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PROFILE_UPDATED=EVENT_PROFILE_UPDATED
KAFKA_TOPIC_PROFILE_DLQ=EVENT_PROFILE_UPDATED_DLQ
KAFKA_CONSUMER_GROUP_ID=finbud-ingestion-consumer
KAFKA_CONSUMER_BATCH_SIZE=100
KAFKA_CONSUMER_BATCH_WAIT_MS=500
KAFKA_CONSUMER_MAX_RETRIES=3
KAFKA_CONSUMER_RETRY_BACKOFF_MS=200

CONSUMER_METRICS_PORT=2113

TELEMETRY_PORT=8081
